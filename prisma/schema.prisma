generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  image         String?
  role          UserRole  @default(PLANNER)
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  weddings      WeddingMember[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

enum UserRole {
  COUPLE
  PLANNER
  COMMITTEE
  VENDOR
  ADMIN
}

// ─── Wedding ──────────────────────────────────────────────────────────────────

model Wedding {
  id                  String          @id @default(uuid())
  name                String
  date                DateTime
  venue               String?
  venueCapacity       Int?
  budget              Decimal         @default(0)
  currency            String          @default("KES")
  culturalType        CulturalType    @default(STANDARD)
  themeColor          String          @default("#8B5CF6")
  themeAccent         String          @default("#F59E0B")
  coverImagePath      String?
  couplePhotoPath     String?
  expectedGuestCount  Int?
  uninvitedBuffer     Int             @default(15)
  palette             String[]        @default([])
  setupComplete       Boolean         @default(false)

  members             WeddingMember[]
  events              WeddingEvent[]
  guests              Guest[]
  vendors             Vendor[]
  payments            Payment[]
  contributions       CommitteeContribution[]
  // timelineEvents removed — replaced by EventProgramItem
  checklistItems      ChecklistItem[]
  budgetLines         BudgetLine[]
  riskAlerts          RiskAlert[]
  mediaItems          MediaItem[]
  auditLogs           AuditLog[]
  activityGroups      ActivityGroup[]
  appointments        Appointment[]
  dowryItems          DowryItem[]
  attireItems         AttireItem[]
  giftRegistryItems   GiftRegistryItem[]
  giftsReceived       GiftReceived[]
  transportRoutes     TransportRoute[]
  accommodations      Accommodation[]
  households          Household[]
  paymentSchedules    PaymentSchedule[]
  incidents           Incident[]
  templateApplications TemplateApplication[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model WeddingMember {
  id                 String    @id @default(uuid())
  weddingId          String
  userId             String
  role               UserRole
  canViewFinancials  Boolean   @default(true)
  wedding            Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([weddingId, userId])
  @@index([weddingId])
}

enum CulturalType {
  STANDARD
  KIKUYU
  LUO
  KAMBA
  KALENJIN
  COASTAL
}

// ─── Wedding Events (Ruracio, Wedding, Post-wedding) ──────────────────────────

model WeddingEvent {
  id                String              @id @default(uuid())
  weddingId         String
  name              String
  type              EventType
  date              DateTime
  startTime         String?
  endTime           String?
  venue             String?
  mapUrl            String?
  description       String?
  isMain            Boolean             @default(false)
  wedding           Wedding             @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guestAttendances  GuestEventAttendance[]
  fromDependencies  EventDependency[]   @relation("FromEvent")
  toDependencies    EventDependency[]   @relation("ToEvent")
  honeymoonDays     HoneymoonDay[]
  programItems      EventProgramItem[]
  checklistItems    ChecklistItem[]
  budgetLines       BudgetLine[]
  appointments      Appointment[]
  transportRoutes   TransportRoute[]
  accommodations    Accommodation[]
  giftRegistry      GiftRegistryItem[]
  giftsReceived     GiftReceived[]
  incidents         Incident[]
  payments          Payment[]
  contributions     CommitteeContribution[]
  mediaItems        MediaItem[]
  vendorAssignments VendorEventAssignment[]
  @@index([weddingId, date])
}

// ─── Event Program (ordered day-of activities) ────────────────────────────────

model EventProgramItem {
  id          String       @id @default(uuid())
  eventId     String
  title       String
  description String?
  startTime   String?      // HH:mm — start of this activity
  endTime     String?      // HH:mm — end of this activity (derived or explicit)
  duration    Int?         // minutes — always stored; derived from start/end or set directly
  order       Int          @default(0)
  assignedTo  String?
  vendorId    String?
  event       WeddingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@index([eventId, order])
}

enum EventType {
  RURACIO
  WEDDING
  RECEPTION
  POST_WEDDING
  TRADITIONAL
  CIVIL
  ENGAGEMENT
  AFTER_PARTY
  HONEYMOON
  MOVING
}

// ─── Event Dependencies ───────────────────────────────────────────────────────

model EventDependency {
  id          String       @id @default(uuid())
  fromEventId String
  toEventId   String
  type        String
  fromEvent   WeddingEvent @relation("FromEvent", fields: [fromEventId], references: [id], onDelete: Cascade)
  toEvent     WeddingEvent @relation("ToEvent", fields: [toEventId], references: [id], onDelete: Cascade)
  @@index([fromEventId])
  @@index([toEventId])
}

// ─── Guest Event Attendance ───────────────────────────────────────────────────

model GuestEventAttendance {
  id         String       @id @default(uuid())
  guestId    String
  eventId    String
  rsvpStatus RsvpStatus   @default(PENDING)
  guest      Guest        @relation(fields: [guestId], references: [id], onDelete: Cascade)
  event      WeddingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  @@unique([guestId, eventId])
  @@index([eventId])
}

// ─── Guests ───────────────────────────────────────────────────────────────────

model Guest {
  id              String        @id @default(uuid())
  localId         String?
  weddingId       String
  name            String
  phone           String?
  email           String?
  rsvpStatus      RsvpStatus    @default(PENDING)
  committeeId     String?
  side            GuestSide     @default(BOTH)
  mealPref        String?
  checkedIn       Boolean       @default(false)
  checkedInAt     DateTime?
  notes           String?
  tags            String[]      @default([])
  plusOneOf       String?
  plusOneAllowed  Boolean       @default(false)
  priority        GuestPriority @default(GENERAL)
  householdId     String?

  version         Int           @default(1)
  checksum        String        @default("")
  updatedBy       String?
  deletedAt       DateTime?
  deletedBy       String?

  wedding         Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  household       Household?    @relation(fields: [householdId], references: [id])
  eventAttendances GuestEventAttendance[]
  guestTransports GuestTransport[]
  guestAccommodations GuestAccommodation[]
  giftsReceived   GiftReceived[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([weddingId, rsvpStatus])
  @@index([weddingId, updatedAt])
  @@index([committeeId, weddingId])
  @@index([householdId])
}

enum GuestPriority {
  VIP
  GENERAL
  OVERFLOW
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
  MAYBE
  WAITLISTED
}

enum GuestSide {
  BRIDE
  GROOM
  BOTH
}

// ─── Household ────────────────────────────────────────────────────────────────

model Household {
  id        String   @id @default(uuid())
  weddingId String
  name      String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guests    Guest[]
  @@index([weddingId])
}

// ─── Vendors ──────────────────────────────────────────────────────────────────

model Vendor {
  id              String        @id @default(uuid())
  weddingId       String
  name            String
  category        VendorCategory
  status          VendorStatus  @default(ENQUIRED)
  contactName     String?
  contactPhone    String?
  contactEmail    String?
  amount          Decimal?
  paidAmount      Decimal       @default(0)
  depositAmount   Decimal?
  depositPaidAt   DateTime?
  contractPath    String?
  lastContactAt   DateTime?
  notes           String?
  description     String?
  isBackup        Boolean       @default(false)
  rating          Int?

  version         Int           @default(1)
  checksum        String        @default("")
  updatedBy       String?
  deletedAt       DateTime?

  wedding         Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  payments        Payment[]
  vendorNotes     VendorNote[]
  paymentSchedules PaymentSchedule[]
  appointments    Appointment[]
  transportRoutes TransportRoute[]
  attireItems     AttireItem[]
  budgetLines     BudgetLine[]
  eventAssignments VendorEventAssignment[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([weddingId, status])
  @@index([weddingId, category])
  @@index([weddingId, lastContactAt])
}

// ─── Vendor Event Assignment ──────────────────────────────────────────────────

model VendorEventAssignment {
  id        String       @id @default(uuid())
  vendorId  String
  eventId   String
  notes     String?

  version   Int          @default(1)
  checksum  String       @default("")
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?

  vendor    Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  event     WeddingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([vendorId, eventId])
  @@index([eventId])
  @@index([vendorId])
}

// ─── Vendor Notes ─────────────────────────────────────────────────────────────

model VendorNote {
  id        String   @id @default(uuid())
  vendorId  String
  weddingId String
  content   String
  createdBy String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@index([vendorId])
}

// ─── Payment Schedule ─────────────────────────────────────────────────────────

model PaymentSchedule {
  id        String   @id @default(uuid())
  vendorId  String
  weddingId String
  dueDate   DateTime
  amount    Decimal
  isPaid    Boolean  @default(false)
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  @@index([weddingId, dueDate])
  @@index([vendorId])
}

enum VendorCategory {
  CATERING
  PHOTOGRAPHY
  VIDEOGRAPHY
  FLORIST
  MUSIC_DJ
  BAND
  TRANSPORT
  DECOR
  CAKE
  ATTIRE
  VENUE
  OFFICIANT
  HAIR_MAKEUP
  ENTERTAINMENT
  SECURITY
  OTHER
}

enum VendorStatus {
  ENQUIRED
  QUOTED
  BOOKED
  CONFIRMED
  CANCELLED
  COMPLETED
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                String        @id @default(uuid())
  weddingId         String
  eventId           String?
  vendorId          String?
  contributionId    String?
  mpesaRef          String?       @unique
  checkoutRequestId String?       @unique
  idempotencyKey    String        @unique
  amount            Decimal
  currency          String        @default("KES")
  status            PaymentStatus @default(PENDING)
  payerName         String?
  payerPhone        String?
  description       String?
  rawCallback       Json?
  processedAt       DateTime?
  reconciledAt      DateTime?

  version           Int           @default(1)
  createdBy         String?
  deletedAt         DateTime?

  wedding           Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event             WeddingEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  vendor            Vendor?       @relation(fields: [vendorId], references: [id])
  contribution      CommitteeContribution? @relation(fields: [contributionId], references: [id])

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([weddingId, createdAt])
  @@index([weddingId, status])
  @@index([vendorId])
  @@index([eventId])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  DUPLICATE
  DISPUTED
  REFUNDED
}

// ─── Committee Contributions ──────────────────────────────────────────────────

model CommitteeContribution {
  id           String       @id @default(uuid())
  weddingId    String
  eventId      String?
  memberId     String
  memberName   String
  pledgeAmount Decimal
  paidAmount   Decimal      @default(0)
  pledgeDate   DateTime     @default(now())
  dueDate      DateTime?
  status       ContribStatus @default(PLEDGED)
  notes        String?
  payments     Payment[]

  wedding      Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event        WeddingEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([weddingId, status])
  @@index([memberId, weddingId])
  @@index([eventId])
}

enum ContribStatus {
  PLEDGED
  PARTIAL
  FULFILLED
  OVERDUE
  CANCELLED
}

// Timeline scheduling replaced by EventProgramItem (day-of program per event)
// and event-scoped ChecklistItem tasks. TimelineEvent model removed.

// ─── Checklist ────────────────────────────────────────────────────────────────

model ChecklistItem {
  id              String         @id @default(uuid())
  weddingId       String
  eventId         String?
  title           String
  description     String?
  category        String?
  phase           PlanningPhase?
  activityGroupId String?
  dueDate         DateTime?
  assignedTo      String?
  assignedToName  String?
  dependsOnId     String?
  isChecked       Boolean        @default(false)
  checkedAt       DateTime?
  checkedBy       String?
  priority        Int            @default(2)
  order           Int            @default(0)
  isFinalCheck    Boolean        @default(false)
  isPrivate       Boolean        @default(false)

  version         Int            @default(1)
  checksum        String         @default("")
  updatedBy       String?
  deletedAt       DateTime?

  wedding         Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event           WeddingEvent?  @relation(fields: [eventId], references: [id])
  activityGroup   ActivityGroup? @relation(fields: [activityGroupId], references: [id])
  reminders       Reminder[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([weddingId, isChecked])
  @@index([weddingId, dueDate])
  @@index([weddingId, category])
  @@index([weddingId, phase])
  @@index([activityGroupId])
  @@index([eventId])
}

enum PlanningPhase {
  BUDGETING
  PLANNING
  PRE_WEDDING
  PROCUREMENT
  DAY_OF
  POST_WEDDING
}

// ─── Activity Groups ──────────────────────────────────────────────────────────

model ActivityGroup {
  id             String         @id @default(uuid())
  weddingId      String
  name           String
  phase          PlanningPhase?
  color          String         @default("#8B5CF6")
  order          Int            @default(0)
  wedding        Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  checklistItems ChecklistItem[]
  @@index([weddingId])
}

// ─── Budget Lines ─────────────────────────────────────────────────────────────

model BudgetLine {
  id            String         @id @default(uuid())
  weddingId     String
  eventId       String?
  phase         PlanningPhase?
  category      String
  description   String
  estimated     Decimal        @default(0)
  actual        Decimal        @default(0)
  committed     Decimal        @default(0)
  vendorId      String?
  vendorName    String?
  notes         String?
  paymentDate   DateTime?
  paymentPlan   String?
  paymentType   String?

  version     Int            @default(1)
  checksum    String         @default("")
  updatedBy   String?
  deletedAt   DateTime?

  wedding     Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event       WeddingEvent?  @relation(fields: [eventId], references: [id])
  vendor      Vendor?        @relation(fields: [vendorId], references: [id])

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([weddingId, category])
  @@index([weddingId, phase])
  @@index([eventId])
  @@index([vendorId])
}

// ─── Risk Alerts ──────────────────────────────────────────────────────────────

model RiskAlert {
  id          String       @id @default(uuid())
  weddingId   String
  ruleId      String
  severity    RiskSeverity
  category    String
  message     String
  data        Json?
  isResolved  Boolean      @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?

  wedding     Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([weddingId, isResolved])
  @@index([weddingId, severity])
}

enum RiskSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

// ─── Media Items ──────────────────────────────────────────────────────────────

model MediaItem {
  id          String    @id @default(uuid())
  weddingId   String
  eventId     String?
  title       String?
  bucket      String
  path        String
  mimeType    String
  sizeBytes   Int?
  linkedToId  String?
  linkedToType String?
  uploadedBy  String?
  deletedAt   DateTime?

  wedding     Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event       WeddingEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([weddingId, createdAt])
  @@index([linkedToId, linkedToType])
  @@index([eventId])
}

// ─── Idempotency + Audit ──────────────────────────────────────────────────────

model ProcessedOperation {
  operationId     String   @id
  processedAt     DateTime @default(now())
  resultCode      Int      @default(200)
  resultServerId  String?
  resultVersion   Int?

  @@index([processedAt])
}

model AuditLog {
  id           String   @id @default(uuid())
  weddingId    String
  actorId      String
  actorRole    String
  action       String
  resourceId   String
  resourceType String
  ipAddress    String?
  prevState    String?
  nextState    String?
  createdAt    DateTime @default(now())

  wedding      Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId, createdAt])
  @@index([resourceId, resourceType])
}

// ─── Appointments ─────────────────────────────────────────────────────────────

model Appointment {
  id          String            @id @default(uuid())
  weddingId   String
  eventId     String?
  title       String
  description String?
  vendorId    String?
  location    String?
  mapUrl      String?
  startAt     DateTime
  endAt       DateTime?
  reminderAt  DateTime?
  status      AppointmentStatus @default(SCHEDULED)
  notes       String?
  createdBy   String

  wedding     Wedding           @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event       WeddingEvent?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  vendor      Vendor?           @relation(fields: [vendorId], references: [id])
  reminders   Reminder[]

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([weddingId, startAt])
  @@index([vendorId])
  @@index([eventId])
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ─── Reminders ────────────────────────────────────────────────────────────────

model Reminder {
  id              String         @id @default(uuid())
  checklistItemId String?
  appointmentId   String?
  triggerAt       DateTime
  channel         String         @default("push")
  sent            Boolean        @default(false)
  checklistItem   ChecklistItem? @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  appointment     Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  @@index([triggerAt, sent])
}

// ─── Incidents ────────────────────────────────────────────────────────────────

model Incident {
  id          String   @id @default(uuid())
  weddingId   String
  eventId     String?
  reportedAt  DateTime @default(now())
  description String
  severity    String
  resolvedAt  DateTime?
  resolvedBy  String?
  resolution  String?
  wedding     Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event       WeddingEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  @@index([weddingId])
  @@index([eventId])
}

// ─── Templates ────────────────────────────────────────────────────────────────

model Template {
  id            String         @id @default(uuid())
  type          TemplateType
  name          String
  culturalType  CulturalType?
  guestSizeMin  Int?
  guestSizeMax  Int?
  phase         PlanningPhase?
  data          Json
  isSystem      Boolean        @default(true)
  applications  TemplateApplication[]
  createdAt     DateTime       @default(now())
}

model TemplateApplication {
  id         String   @id @default(uuid())
  weddingId  String
  templateId String
  appliedAt  DateTime @default(now())
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  template   Template @relation(fields: [templateId], references: [id])
  @@index([weddingId])
}

enum TemplateType {
  CHECKLIST
  BUDGET
  TIMELINE
  VENDOR_LIST
  APPOINTMENT
  ACTIVITY_GROUP
  GUEST_TAGS
}

// ─── Dowry Items ──────────────────────────────────────────────────────────────

model DowryItem {
  id             String      @id @default(uuid())
  weddingId      String
  name           String
  quantity       Int         @default(1)
  estimatedValue Decimal?
  agreedValue    Decimal?
  status         DowryStatus @default(PENDING)
  notes          String?
  wedding        Wedding     @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  @@index([weddingId])
}

enum DowryStatus {
  PENDING
  AGREED
  DELIVERED
}

// ─── Attire Items ─────────────────────────────────────────────────────────────

model AttireItem {
  id            String   @id @default(uuid())
  weddingId     String
  person        String
  description   String
  fabricSource  String?
  tailorVendorId String?
  fittingDate   DateTime?
  status        String   @default("PENDING")
  wedding       Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  tailor        Vendor?  @relation(fields: [tailorVendorId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([weddingId])
}

// ─── Gift Registry ────────────────────────────────────────────────────────────

model GiftRegistryItem {
  id             String   @id @default(uuid())
  weddingId      String
  eventId        String?
  name           String
  description    String?
  url            String?
  estimatedPrice Decimal?
  quantity       Int      @default(1)
  priority       Int      @default(2)
  wedding        Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event          WeddingEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([weddingId])
  @@index([eventId])
}

model GiftReceived {
  id              String      @id @default(uuid())
  weddingId       String
  eventId         String?
  guestId         String?
  giverName       String
  description     String
  estimatedValue  Decimal?
  status          GiftStatus  @default(RECEIVED)
  receivedAt      DateTime    @default(now())
  thankYouSent    Boolean     @default(false)
  thankYouSentAt  DateTime?
  wedding         Wedding     @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event           WeddingEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  guest           Guest?      @relation(fields: [guestId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  @@index([weddingId])
  @@index([eventId])
}

enum GiftStatus {
  RECEIVED
  THANKED
  RETURNED
}

// ─── Logistics & Transport ────────────────────────────────────────────────────

model TransportRoute {
  id                String          @id @default(uuid())
  weddingId         String
  eventId           String?
  name              String
  departureLocation String
  arrivalLocation   String
  departureTime     DateTime
  capacity          Int?
  assignedVendorId  String?
  wedding           Wedding         @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event             WeddingEvent?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  assignedVendor    Vendor?         @relation(fields: [assignedVendorId], references: [id])
  guestTransports   GuestTransport[]
  createdAt         DateTime        @default(now())
  @@index([weddingId])
  @@index([eventId])
}

model GuestTransport {
  id      String         @id @default(uuid())
  guestId String
  routeId String
  guest   Guest          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  route   TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  @@unique([guestId, routeId])
}

model Accommodation {
  id           String               @id @default(uuid())
  weddingId    String
  eventId      String?
  hotelName    String
  address      String?
  checkIn      DateTime
  checkOut     DateTime
  roomsBlocked Int?
  notes        String?
  wedding      Wedding              @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event        WeddingEvent?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  guestAccommodations GuestAccommodation[]
  createdAt    DateTime             @default(now())
  @@index([weddingId])
  @@index([eventId])
}

model GuestAccommodation {
  id              String        @id @default(uuid())
  guestId         String
  accommodationId String
  roomNumber      String?
  guest           Guest         @relation(fields: [guestId], references: [id], onDelete: Cascade)
  accommodation   Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
  @@unique([guestId, accommodationId])
}

// ─── Honeymoon ────────────────────────────────────────────────────────────────

model HoneymoonDay {
  id          String       @id @default(uuid())
  eventId     String
  date        DateTime
  title       String
  description String?
  location    String?
  mapUrl      String?
  event       WeddingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  @@index([eventId])
}
